<script>
const slides=[...document.querySelectorAll('.slide')];
let current=0;
function show(i){current=(i+slides.length)%slides.length;slides.forEach((s,idx)=>s.classList.toggle('active',idx===current));document.getElementById('progress').style.width=((current+1)/slides.length*100)+'%';}
function nextSlide(){show(current+1)}
function prevSlide(){show(current-1)}
document.addEventListener('keydown',e=>{if(['ArrowLeft','PageDown',' '].includes(e.key))nextSlide(); if(['ArrowRight','PageUp'].includes(e.key))prevSlide();});
slides.forEach((s,idx)=>{const f=s.querySelector('.footer span:last-child'); if(f) f.textContent=idx+1;});
show(0);
</script>
